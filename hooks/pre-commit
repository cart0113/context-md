#!/usr/bin/env bash
#
# pre-commit — Format staged files and run TOC script tests.
#
# Runs:
#   1. prettier on staged md/js/ts/json/css/yaml files
#   2. ruff on staged python files
#   3. cache-bust docs/index.html if docs changed
#   4. TOC script tests if the script or tests changed
#   5. regenerate docs/src/reference/config-effects.md if dispatcher,
#      prompt templates, the example fixture, or the generator changed
#   6. regenerate docs/src/reference/cli.md if dispatcher, prompt
#      templates, or the generator changed
#
# Install:
#   cp hooks/pre-commit .git/hooks/pre-commit
#   chmod +x .git/hooks/pre-commit

set -eo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

# ── 1. Prettier on staged web/markdown files ────────────────────────────────

PRETTIER="./node_modules/.bin/prettier"
if [ -x "$PRETTIER" ]; then
    PRETTIER_FILES=$(git diff --cached --name-only --diff-filter=ACM \
        | grep -E '\.(md|js|ts|jsx|tsx|json|css|html|yaml|yml)$' \
        || true)

    if [ -n "$PRETTIER_FILES" ]; then
        echo "$PRETTIER_FILES" | while IFS= read -r file; do
            [ -f "$file" ] || continue
            "$PRETTIER" --write "$file" 2>/dev/null || true
            git add "$file" 2>/dev/null || true
        done
    fi
fi

# ── 2. Ruff on staged Python files ──────────────────────────────────────────

RUFF="$(command -v ruff-main 2>/dev/null || true)"
if [ -n "$RUFF" ]; then
    PY_FILES=$(git diff --cached --name-only --diff-filter=ACM \
        | grep -E '\.py$' \
        || true)

    if [ -n "$PY_FILES" ]; then
        echo "$PY_FILES" | while IFS= read -r file; do
            [ -f "$file" ] || continue
            "$RUFF" format "$file" 2>/dev/null || true
            "$RUFF" check --fix "$file" 2>/dev/null || true
            git add "$file" 2>/dev/null || true
        done
    fi
fi

# ── 3. Cache-bust docs/index.html ──────────────────────────────────────────

DOCS_DIR="${REPO_ROOT}/docs"
if [ -f "${DOCS_DIR}/index.html" ] && git diff --cached --name-only | grep -qE '^docs/'; then
    STAMP=$(date +%Y%m%d%H%M%S)
    sed -i '' "s/?v=[0-9a-zA-Z]*/?v=${STAMP}/g" "${DOCS_DIR}/index.html"
    git add "${DOCS_DIR}/index.html"
fi

# ── 4. TOC script tests (if script or tests changed) ───────────────────────

TOC_FILES=$(git diff --cached --name-only \
    | grep -E '(context-db-generate-toc\.sh|tests/test_toc_script\.py)' \
    || true)

if [ -n "$TOC_FILES" ]; then
    echo "Running TOC script tests..."
    python3 -m unittest tests.test_toc_script 2>&1 || {
        echo "TOC script tests failed — fix before committing."
        exit 1
    }
fi

# ── 5. Regenerate config-effects docs page if inputs changed ───────────────

CONFIG_EFFECTS_INPUTS=$(git diff --cached --name-only \
    | grep -E '^(templates/skills/context-db/scripts/|\.claude/skills/context-db/scripts/|example/acme-payments-repo/|bin/build-config-effects-docs\.py)' \
    || true)

if [ -n "$CONFIG_EFFECTS_INPUTS" ]; then
    echo "Regenerating docs/src/reference/config-effects.md..."
    python3 bin/build-config-effects-docs.py >/dev/null || {
        echo "config-effects generator failed — fix before committing."
        exit 1
    }
    git add docs/src/reference/config-effects.md
fi

# ── 6. Regenerate CLI reference if dispatcher or prompt templates changed ──

CLI_REFERENCE_INPUTS=$(git diff --cached --name-only \
    | grep -E '^(templates/skills/context-db/scripts/|\.claude/skills/context-db/scripts/|bin/build-cli-reference\.py)' \
    || true)

if [ -n "$CLI_REFERENCE_INPUTS" ]; then
    echo "Regenerating docs/src/reference/cli.md..."
    python3 bin/build-cli-reference.py >/dev/null || {
        echo "cli-reference generator failed — fix before committing."
        exit 1
    }
    git add docs/src/reference/cli.md
fi
